# ─── Frontend environment variables ─────────────────────────────────────────
# Copy this file to .env in the /crisisbrain root (same folder as package.json)
# Then run: npm start

# Leave empty when running backend locally (proxy in package.json handles it)
# Set to your Cloud Run URL after deploying backend:
# REACT_APP_BACKEND_URL=https://crisisbrain-api-xxxx-uc.a.run.app
REACT_APP_BACKEND_URL=
